{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Witt",
  "version": "0.1.0",
  "identifier": "com.witt.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Witt",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.svg"
    ],
    "category": "Education",
    "shortDescription": "Personal language asset engine",
    "longDescription": "Witt helps you build semantic understanding through multi-context word capture.",
    "macOS": {
      "entitlements": "entitlements.mac.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "globalShortcut": {
      "platforms": {
        "macOS": {
          "enabled": true
        },
        "windows": {
          "enabled": true
        },
        "linux": {
          "enabled": true
        }
      }
    }
  }
}
